# Compose project
COMPOSE_PROJECT_NAME=retrievaller

# Backend
BACKEND_PORT=8089

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_HOST_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=retrievaller
MYSQL_USER=retrievaller
MYSQL_PASSWORD=retrievaller

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379
REDIS_DB=0
REDIS_RESULT_DB=1

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=retrievaller
MINIO_SECRET_KEY=retrievaller
MINIO_ROOT_USER=retrievaller
MINIO_ROOT_PASSWORD=retrievaller
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_SECURE=false
MINIO_BUCKET_DOCUMENTS=rag-documents
MINIO_BUCKET_PARSED_RESULTS=rag-parsed-results

# etcd
ETCD_CLIENT_PORT=2379

# Milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_HOST_PORT=19530
MILVUS_HEALTH_PORT=9091
MILVUS_COLLECTION_DOCUMENT_CHUNKS=document_chunks

# Embedding
EMBEDDING_MODEL_NAME=quentinz/bge-large-zh-v1.5:latest
EMBEDDING_DIMENSION=1024
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Health check
HEALTH_CHECK_TIMEOUT_SECONDS=2
